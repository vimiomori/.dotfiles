# This is Git's per-user configuration file.
# Per-user identity is set via includeIf (see bottom of file).
[push]
	default = simple
	autoSetupRemote = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[ghq]
	root = ~/code/src
[alias]
  lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
	st = status
	co = checkout
	br = branch
	rb = rebase
	ci = commit
	ad = "!git ls-files --modified --others --exclude-standard | peco --initial-filter=Fuzzy | xargs git add "
	alias = ! git config --get-regexp ^alias\\. | sed -e s/^alias\\.// -e s/\\ /\\ =\\ /
	update = !git pull && git submodule update
[core]
	excludesfile = ~/.gitignore
	editor = vim
[diff]
	tool = nvimdiff
[merge]
	tool = nvimdiff
[rerere]
	enabled = true
[credential]
	helper = cache
# Per-user identity and SSH routing by directory.
# Repos under ~/code/src/github.com/vimiomori/ use vi's key.
# Repos under ~/code/src/github.com/scootyboots/ use scott's key.
# Everything else falls back to vi.
[includeIf "gitdir:~/code/src/github.com/vimiomori/"]
	path = ~/.gitconfig-vi
[includeIf "gitdir:~/code/src/github.com/scootyboots/"]
	path = ~/.gitconfig-scott
[include]
	path = ~/.gitconfig-vi
