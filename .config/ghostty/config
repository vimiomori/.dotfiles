# Ghostty configuration
# Docs: https://ghostty.org/docs/config/reference

# Use zsh (Omarchy defaults to bash as login shell)
command = /usr/bin/zsh

font-family = JetBrainsMono Nerd Font
font-size = 9

# Theme -- match alacritty colors
background = #003955
foreground = #b4f9f8
cursor-color = #30FFF2

# Window
window-padding-x = 14
window-padding-y = 14
